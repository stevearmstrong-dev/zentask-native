{
  "name": "zentask-native",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "android": "expo start --android",
    "build:ios:dev": "npx eas-cli build --platform ios --profile development --local",
    "build:ios:preview": "npx eas-cli build --platform ios --profile preview --local",
    "build:ios:testflight": "npx eas-cli build --platform ios --profile testflight --local",
    "ios": "npx expo run:ios",
    "ios:select": "npx expo run:ios --device",
    "start": "expo start",
    "start:dev-client": "expo start --dev-client --tunnel",
    "start:tunnel": "expo start --tunnel",
    "update:development": "npx eas-cli update --channel development",
    "update:preview": "npx eas-cli update --channel preview",
    "update:production": "npx eas-cli update --channel production",
    "web": "expo start --web"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.1.1",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-community/datetimepicker": "^9.1.0",
    "@react-native-google-signin/google-signin": "^16.1.2",
    "@react-navigation/bottom-tabs": "^7.15.9",
    "@react-navigation/native": "^7.2.2",
    "@react-navigation/native-stack": "^7.14.11",
    "@react-navigation/stack": "^7.8.10",
    "@supabase/supabase-js": "^2.103.0",
    "expo": "~54.0.33",
    "expo-dev-client": "~6.0.20",
    "expo-haptics": "^55.0.14",
    "expo-linear-gradient": "^15.0.8",
    "expo-notifications": "^55.0.19",
    "expo-status-bar": "~3.0.9",
    "expo-updates": "~29.0.16",
    "expo-web-browser": "~15.0.10",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "^2.31.1",
    "react-native-keyboard-aware-scroll-view": "^0.9.5",
    "react-native-safe-area-context": "^5.6.0",
    "react-native-screens": "^4.16.0",
    "react-native-swipeable": "^0.6.0",
    "react-native-url-polyfill": "^3.0.0"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
